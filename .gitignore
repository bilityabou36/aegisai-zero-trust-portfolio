# Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform plan files
*.tfplan
tfplan

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.auto.tfvars
*.auto.tfvars.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# macOS
.DS_Store
